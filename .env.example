# Copy this to .env and fill in values

# Database — PostgreSQL (required for Vercel; SQLite is not supported on serverless)
# Local: Docker, Neon dev branch, or Supabase. Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/medbook"

# --- Vercel checklist (if register still fails):
# 1) Commit and push the folder prisma/migrations/ (migrations must be in Git).
# 2) Vercel → Settings → Environment Variables: DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL (https://your-app.vercel.app).
# 3) If the Git repo root is the parent folder, set Vercel Root Directory to: medbook
# 4) After deploy, open https://YOUR_APP/api/health — should say database: "connected".
# 5) One-time: npm run db:seed — loads demo doctors + time slots (PostgreSQL starts empty vs old SQLite).

# Auth Secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
# Local: http://localhost:3050  |  Vercel: https://your-project.vercel.app (exact production URL)
NEXTAUTH_URL="http://localhost:3050"

# --- AI chat (POST /api/chat) — set at least one provider
# Groq (fast, generous free tier) — https://console.groq.com/keys
GROQ_API_KEY=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
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite
# GEMINI_API_KEY=  (alias for GOOGLE_GENERATIVE_AI_API_KEY)

# OpenAI — optional fallback — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# CHAT_PROVIDER: auto | groq | gemini | openai
# auto = try Gemini first, then Groq on quota, then OpenAI
# CHAT_PROVIDER=groq
#
# Groq path: AI can call create_appointment (doctor name, YYYY-MM-DD, HH:mm, reason) when the user is
# signed in (session cookie). Matches an open TimeSlot in the DB — run npm run db:seed for demo slots.

# --- Optional: Anthropic Claude — https://console.anthropic.com


# Optional: force one provider: openai | gemini | anthropic
# AI_PROVIDER=gemini

# Optional: override default Claude model (default in code is claude-3-5-sonnet-20241022)
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# Optional: standalone chat API (npm run chat-server) listens on 3456 by default
# PORT=3456
