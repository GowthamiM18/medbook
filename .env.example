# Copy this to .env and fill in values

# Database (SQLite for local dev - no setup needed!)
DATABASE_URL="file:./prisma/dev.db"

# Auth Secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
# Must match the URL you use in the browser (dev server uses port 3050 — see package.json "dev")
NEXTAUTH_URL="http://localhost:3050"

# --- OpenAI (ChatGPT API) — https://platform.openai.com/api-keys
# If set, used before Gemini/Anthropic unless AI_PROVIDER forces another backend.
OPENAI_API_KEY=
# Optional model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --- Free tier: Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: model id if the default fails (try gemini-2.0-flash or gemini-1.5-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Optional: Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: force one provider: openai | gemini | anthropic
# AI_PROVIDER=gemini

# Optional: override default Claude model (default in code is claude-3-5-sonnet-20241022)
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# Optional: standalone chat API (npm run chat-server) listens on 3456 by default
# PORT=3456
